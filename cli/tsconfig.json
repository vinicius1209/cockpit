{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "lib": ["ESNext", "DOM"],
    "types": ["node", "bun"],
    "verbatimModuleSyntax": false,
    "noEmit": true
  },
  "include": ["src/**/*"]
}
