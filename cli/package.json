{
  "name": "cockpit-cli",
  "version": "0.8.0",
  "description": "Cockpit CLI — orchestrate workspaces, cards and agents from your terminal",
  "type": "module",
  "private": true,
  "bin": {
    "cockpit": "./src/index.ts",
    "ck": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --outfile=dist/cockpit",
    "link": "bun link",
    "test": "bun test src/__tests__/",
    "test:watch": "bun test --watch src/__tests__/"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.13"
  }
}
